# ============================================
# 思政题库刷题应用 - 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值
# ============================================

# ---- 数据库配置 (PostgreSQL 兼容协议) ----
# 支持 Supabase、Neon 等云数据库
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://user:password@localhost:5432/sizheng_quiz

# ---- AI 接口配置 (OpenAI 兼容协议) ----
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_API_KEY=sk-your-api-key-here
AI_MODEL_NAME=deepseek-chat
# 单题AI生成最大次数（默认2次：1次初始+1次重新生成）
AI_GENERATE_LIMIT=2
# AI请求超时时间（毫秒）
AI_REQUEST_TIMEOUT=30000

# ---- 管理员配置 ----
# 管理员用户名
ADMIN_USERNAME=admin
# 管理员密码（务必修改！）
ADMIN_PASSWORD=change-me-please
# 管理员Token（Bearer认证，与用户名密码二选一）
ADMIN_TOKEN=
# 是否开放注册（true/false）
ALLOW_REGISTRATION=false

# ---- 应用配置 ----
# 前端公开变量（NEXT_PUBLIC_ 前缀会暴露给浏览器，不要放敏感信息）
# NEXT_PUBLIC_APP_NAME=思政题库刷题
# NEXT_PUBLIC_APP_VERSION=1.0.0
